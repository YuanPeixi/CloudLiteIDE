{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Executor": {
    "Mode": "Native",
    "LeaseTtlSeconds": 120,
    "RunTimeoutSeconds": 10,
    "CompileTimeoutSeconds": 10,
    "MaxOutputBytes": 1048576,
    "MaxMemoryMb": 256,
    "MaxCpuPercent": 80
  },
  "AllowedHosts": "*"
}
